# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=carecanvas
POSTGRES_PASSWORD=carecanvas_secret
POSTGRES_DB=carecanvas
DATABASE_URL=postgresql://carecanvas:carecanvas_secret@localhost:5433/carecanvas

# ─── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_AUTH=neo4j/carecanvas_secret
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=carecanvas_secret

# ─── Elasticsearch ─────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ─── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ─── MinIO / S3 ────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=carecanvas
MINIO_ROOT_PASSWORD=carecanvas_secret
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET_CANVAS=carecanvas-canvas
MINIO_BUCKET_BLUEPRINTS=carecanvas-blueprints
S3_ACCESS_KEY=carecanvas
S3_SECRET_KEY=carecanvas_secret

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=carecanvas_secret

# ─── FHIR Server ───────────────────────────────────────────────────────────────
FHIR_SERVER_URL=http://localhost:8080/fhir

# ─── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=verander_dit_naar_een_veilig_geheim_in_productie
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=verander_dit_naar_een_ander_veilig_geheim
JWT_REFRESH_EXPIRES_IN=30d

# ─── API server ────────────────────────────────────────────────────────────────
API_PORT=4001
API_URL=http://localhost:4001
NODE_ENV=development

# ─── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4001
NEXTAUTH_URL=http://localhost:4000
NEXTAUTH_SECRET=verander_dit_naar_een_veilig_geheim_in_productie

# ─── Claude API (Anthropic) ────────────────────────────────────────────────────
# Vervang door jouw API key zodra beschikbaar
ANTHROPIC_API_KEY=sk-ant-PLACEHOLDER
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Overig ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:4000
